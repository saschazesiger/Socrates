# ── Telegram (MTProto userbot — a REAL user account, not a bot) ─────────────
# api_id / api_hash from https://my.telegram.org -> "API development tools".
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# StringSession for the persona's account.
# NO LONGER REQUIRED HERE: the session is now managed at runtime in settings.json
# (S3) and is easiest to mint from the dashboard → Connection (phone + code + 2FA).
# If you set a value here it only SEEDS settings.json on first boot.
# You can still produce one locally with:  npm run login
TELEGRAM_SESSION=

# Comma-separated Telegram user IDs the persona talks to.
# OPTIONAL / SEED ONLY: the allow-list (and an "allow everyone" toggle) now live
# in settings.json and are editable in the dashboard → Settings. A value here is
# only used to seed the initial list on first boot.
ALLOWED_USER_IDS=11111111,22222222

# ── OpenRouter ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Models are now selected in the dashboard → Settings (stored in settings.json).
# The values below are OPTIONAL and only SEED settings.json on first boot.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_MEDIA_MODEL=google/gemini-3.1-flash-lite

# ── S3 (persistent storage: settings.json + per-contact chat/memory/state) ──
# Endpoint may be given with or without https:// (added automatically).
S3_ENDPOINT=hel1.your-objectstorage.com
S3_REGION=eu-central-1
S3_BUCKET=my-bucket
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
# Optional key prefix inside the bucket (no leading slash)
S3_PREFIX=socrates

# ── Dashboard ─────────────────────────────────────────────────────────────
# Password for the admin dashboard at "/". If unset, the dashboard is disabled.
# This now also gates Telegram login and model/account settings, so make it strong.
DASHBOARD_PASSWORD=change-me

# ── App ───────────────────────────────────────────────────────────────────
PORT=3000
# IANA timezone of the imitated person (used for "what time is it for me right now")
PERSON_TIMEZONE=Asia/Hong_Kong
